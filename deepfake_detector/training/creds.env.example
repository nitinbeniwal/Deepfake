# Copy this file to  creds.env  (same folder) and fill in your OWN tokens.
# creds.env is gitignored — it is NEVER committed. Do not paste tokens anywhere else.
#
# Get tokens:
#   Kaggle      : https://www.kaggle.com/settings  -> API -> Create New Token
#   HuggingFace : https://huggingface.co/settings/tokens -> New token (Read)
#   ModelScope  : https://modelscope.cn -> Account -> Access Token   (optional, only for DDL)

# --- Kaggle ---
# Easiest: download kaggle.json from the site and put it at  %USERPROFILE%\.kaggle\kaggle.json
# OR set these two from that json:
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Hugging Face (faster + gated dataset downloads) ---
HF_TOKEN=

# --- ModelScope (optional, only if you enable the big DDL dataset) ---
MODELSCOPE_TOKEN=
